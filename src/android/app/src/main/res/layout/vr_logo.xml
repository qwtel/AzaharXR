<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:layout_gravity="center_horizontal"
    >
    <ImageView
        android:id="@+id/image_logo"
        android:layout_width="104dp"
        android:layout_height="104dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_citra_full"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <TextView
        android:id="@+id/materialTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:fontFamily="@font/lato_bold"
        android:gravity="center"
        android:text="Azahar"
        android:textSize="54sp"
        android:translationY="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/image_logo"
        app:layout_constraintStart_toEndOf="@+id/image_logo" />

    <org.citra.citra_emu.ui.GradientTextView
        android:id="@+id/xrTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/dancing_script_bold"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:text="XR"
        android:textColor="@color/vr_azahar_wordmark_gradient_mid"
        android:textSize="64sp"
        android:translationX="-6dp"
        android:translationY="-12dp"
        app:layout_constraintBottom_toBottomOf="@+id/materialTextView"
        app:layout_constraintStart_toEndOf="@+id/materialTextView" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/lato_bold"
        android:gravity="center"
        android:text="(Beta)"
        android:textSize="32sp"
        android:translationY="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/materialTextView"
        app:layout_constraintStart_toEndOf="@+id/xrTextView" />

</androidx.constraintlayout.widget.ConstraintLayout>
